generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile                UserProfile?
  snapshots              PortfolioSnapshot[]
  reports                PortfolioReport[]
  extractions            RawExtraction[]
  analysisRuns           AnalysisRun[]
  notificationEvents     NotificationEvent[]
  notificationRecipients NotificationRecipient[]
  watchlistIdeas         WatchlistIdea[]
  convictions            UserConviction[]
}

model UserProfile {
  id                                    String   @id @default(cuid())
  userId                                String   @unique
  user                                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  birthYear                             Int
  targetRetirementAge                   Int      @default(65)
  employmentStatus                      String?
  profession                            String?
  annualIncomeRange                     String?
  jobStabilityVolatility                String?
  emergencyFundMonths                   Float?
  separateRetirementAssetsAmount        Float?
  separateRetirementAccountsDescription String?
  retirementAccountAssetMix             String?
  trackedAccountObjective               String
  trackedAccountRiskTolerance           String
  trackedAccountStyle                   String?
  permittedAssetClasses                 String?
  trackedAccountTimeHorizon             String?
  trackedAccountTaxStatus               String?
  maxDrawdownTolerancePct               Float?
  leverageOptionsPermitted              String?
  targetNumberOfHoldings                Int?
  maxPositionSizePct                    Float?
  sectorsToEmphasize                    String?
  sectorsToAvoid                        String?
  notes                                 String?
  createdAt                             DateTime @default(now())
  updatedAt                             DateTime @updatedAt
}

model PortfolioSnapshot {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  notes        String?
  confirmed    Boolean   @default(false)
  archivedAt   DateTime?
  archiveLabel String?

  holdings     Holding[]
  reports      PortfolioReport[]
  analysisRuns AnalysisRun[]
}

model Holding {
  id             String            @id @default(cuid())
  snapshotId     String
  snapshot       PortfolioSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  ticker         String
  companyName    String?
  shares         Float
  currentPrice   Float?
  currentValue   Float?
  dailyChangePct Float?
  lastBoughtAt   DateTime?
  isCash         Boolean           @default(false)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model RawExtraction {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rawText   String
  imageUrl  String?
  createdAt DateTime @default(now())
}

model PortfolioReport {
  id            String            @id @default(cuid())
  userId        String
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  snapshotId    String
  snapshot      PortfolioSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  analysisRunId String?
  analysisRun   AnalysisRun?      @relation(fields: [analysisRunId], references: [id])
  summary       String?
  reasoning     String?
  marketContext String?
  createdAt     DateTime          @default(now())

  recommendations HoldingRecommendation[]
}

model HoldingRecommendation {
  id                  String          @id @default(cuid())
  reportId            String
  report              PortfolioReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  ticker              String
  companyName         String?
  role                String?
  currentShares       Float
  targetShares        Float
  shareDelta          Float
  currentWeight       Float
  targetWeight        Float
  valueDelta          Float
  dollarDelta         Float?
  acceptableRangeLow  Float?
  acceptableRangeHigh Float?
  action              String
  confidence          String?
  positionStatus      String?
  evidenceQuality     String?
  thesisSummary       String?
  detailedReasoning   String?
  whyChanged          String?
  systemNote          String?
  reasoningSources    String?
}

model AnalysisRun {
  id                   String            @id @default(cuid())
  userId               String
  user                 User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  snapshotId           String
  snapshot             PortfolioSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  triggerType          String
  triggeredBy          String?
  status               String            @default("pending")
  errorMessage         String?
  alertLevel           String?
  alertReason          String?
  profileSnapshot      String?
  portfolioMathSummary String?
  sourceQualitySummary String?
  researchCoverage     String?
  inputTokens          Int?
  outputTokens         Int?
  modelUsed            String?
  retryCount           Int               @default(0)
  qualityMeta          String?
  sseEventLog          String?
  isCronRun            Boolean           @default(false)
  startedAt            DateTime          @default(now())
  completedAt          DateTime?

  reports            PortfolioReport[]
  changeLogs         RecommendationChangeLog[]
  notificationEvents NotificationEvent[]
  watchlistIdeas     WatchlistIdea[]
  evidencePacket     EvidencePacket?
}

model EvidencePacket {
  id                  String      @id @default(cuid())
  runId               String      @unique
  run                 AnalysisRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  schemaVersion       Int         @default(1)
  snapshotId          String
  frozenAt            DateTime    @default(now())
  holdingsJson        String
  newsJson            String
  sentimentJson       String
  valuationJson       String
  correlationJson     String
  regimeJson          String
  candidatesJson      String
  promptHash          String?
  totalInputChars     Int         @default(0)
  perSectionCharsJson String      @default("{}")
  outcome             String      @default("pending")
  createdAt           DateTime    @default(now())

  @@index([snapshotId])
  @@index([promptHash])
  @@index([outcome])
}

model RecommendationChangeLog {
  id                String      @id @default(cuid())
  runId             String
  run               AnalysisRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  ticker            String
  companyName       String?
  priorAction       String?
  newAction         String
  priorRole         String?
  newRole           String?
  priorTargetShares Float?
  newTargetShares   Float
  sharesDelta       Float
  deltaDollar       Float?
  priorWeight       Float?
  newWeight         Float
  deltaWeight       Float?
  changed           Boolean     @default(false)
  evidenceDriven    Boolean     @default(false)
  changeReason      String?
  whyChanged        String?
  createdAt         DateTime    @default(now())
}

model NotificationEvent {
  id           String       @id @default(cuid())
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  runId        String?
  run          AnalysisRun? @relation(fields: [runId], references: [id])
  reportId     String?
  type         String
  channel      String
  recipient    String?
  subject      String?
  status       String       @default("pending")
  errorMessage String?
  isDebug      Boolean      @default(false)
  createdAt    DateTime     @default(now())
}

model NotificationRecipient {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email     String
  label     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model WatchlistIdea {
  id                        String      @id @default(cuid())
  userId                    String
  user                      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  runId                     String
  run                       AnalysisRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  ticker                    String
  companyName               String?
  role                      String?
  rationale                 String?
  whyNow                    String?
  profileFitReason          String?
  recommendedStarterShares  Float?
  recommendedStarterDollars Float?
  recommendedStarterWeight  Float?
  wouldReduceTicker         String?
  confidence                String?
  evidenceQuality           String?
  createdAt                 DateTime    @default(now())
}

model UserConviction {
  id        String              @id @default(cuid())
  userId    String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticker    String
  rationale String
  active    Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  messages  ConvictionMessage[]
}

model ConvictionMessage {
  id            String         @id @default(cuid())
  convictionId  String
  conviction    UserConviction @relation(fields: [convictionId], references: [id], onDelete: Cascade)
  role          String
  content       String
  analysisRunId String?
  createdAt     DateTime       @default(now())

  @@index([analysisRunId])
  @@index([convictionId, createdAt])
}

model AppSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
